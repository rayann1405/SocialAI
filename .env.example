# ----- Database (PostgreSQL) -----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/socialai?schema=public"

# ----- NextAuth -----
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ----- Google OAuth (optional bonus) -----
# Leave empty to disable the "Continuer avec Google" button.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Publish queue -----
# mock (default, in-process) | bullmq (requires REDIS_URL, not implemented in MVP)
QUEUE_DRIVER="mock"
# REDIS_URL="redis://localhost:6379"

# Protects the /api/cron/publish endpoint (optional).
CRON_SECRET=""
